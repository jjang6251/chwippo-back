# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
# 로컬: DB_HOST=localhost, DB_SSL=false
# EC2 프로덕션: DB_HOST=DB EC2 사설 IP, DB_SSL=false (동일 VPC 내부 통신)
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=chwippo
DB_SSL=false

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# Kakao 친구톡 (MVP 2차)
KAKAO_CHANNEL_ID=
KAKAO_ADMIN_KEY=

# Cloudflare R2 (S3 호환) — 파일 업로드
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chwippo
R2_PUBLIC_URL=

# 사용자당 저장 용량 한도 (MB)
MAX_STORAGE_PER_USER_MB=100

# Admin
ADMIN_EMAIL=
ADMIN_KAKAO_ID=

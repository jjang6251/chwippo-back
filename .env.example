# ─────────────────────────────────────────────────────────
# 백엔드 환경변수 (.env.example)
#
# 이 파일을 .env로 복사해서 값을 채워 사용.
# 실제 운영 값은 별도 비공개 문서/시크릿 매니저에서 관리.
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=chwippo
DB_SSL=false

# JWT (각 환경별로 다른 시크릿 사용 — `openssl rand -base64 32`)
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Kakao OAuth
# Redirect URI는 로컬 개발 시 http://localhost:3000/auth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# Kakao 친구톡 (MVP 2차)
KAKAO_CHANNEL_ID=
KAKAO_ADMIN_KEY=

# Cloudflare R2 (S3 호환) — 파일 업로드
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# 사용자당 저장 용량 한도 (MB)
MAX_STORAGE_PER_USER_MB=100

# Admin (자동으로 role=admin 부여될 카카오 사용자 ID)
ADMIN_EMAIL=
ADMIN_KAKAO_ID=

# OpenAI (F5+ AI 기능 — note_summary, 면접 prep 등)
OPENAI_API_KEY=
OPENAI_MODEL_LIGHT=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# Anthropic (PR 0+ — 자소서 등 한국어 중심 feature). key 없으면 해당 feature 호출 시 차단됨
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_HEAVY=claude-sonnet-4-6

# PR 1 — AbuserBanService Discord webhook (3일 연속 한도 도달 자동 ban 알림). 미설정 시 ban 발동 + webhook skip
ADMIN_ALERT_WEBHOOK_URL=

# DART OPEN API — W2 회사명 자동완성 시드 + /companies/details 회사 정보 endpoint
# 무료 발급: opendart.fss.or.kr (일 10000회·분 100회)
# 미설정 시 details 503 silent skip, autocomplete 는 기존 companies.json 으로 정상 동작
DART_API_KEY=
